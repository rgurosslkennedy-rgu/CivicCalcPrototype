<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>CivicCalc Africa Prototype</title>
    <style>
        /* Streamlit Color Palette Variables */
        :root {
            --bg-primary: #ffffff;
            --bg-secondary: #f0f2f6;
            --text-color: #31333F;
            --accent-color: #ff4b4b;
            --border-color: #dfe2e6;
            --base-font-size: 16px;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-primary);
            color: var(--text-color);
            font-size: var(--base-font-size);
            margin: 0;
            display: flex;
            min-height: 100vh;
            transition: background 0.2s, color 0.2s, font-size 0.2s;
        }

        /* Streamlit Left Sidebar Layout */
        aside {
            width: 320px;
            background-color: var(--bg-secondary);
            padding: 2rem 1.5rem;
            border-right: 1px solid var(--border-color);
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Streamlit Main Frame Layout */
        main {
            flex: 1;
            padding: 2rem 3rem;
            box-sizing: border-box;
            max-width: 900px;
        }

        h1, h2, h3 {
            margin-top: 0;
            color: var(--text-color);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        label {
            font-weight: 600;
        }

        select, input, button {
            padding: 0.6rem;
            border-radius: 4px;
            border: 1px solid var(--border-color);
            background-color: var(--bg-primary);
            color: var(--text-color);
            font-size: 1rem;
            box-sizing: border-box;
            width: 100%;
        }

        /* Streamlit Button Accent Styling */
        button.run-btn {
            background-color: var(--accent-color);
            color: white;
            border: none;
            font-weight: bold;
            cursor: pointer;
            padding: 0.8rem;
        }

        button.run-btn:hover {
            opacity: 0.9;
        }

        /* Streamlit Message Box Styling */
        .output-card {
            background-color: var(--bg-secondary);
            border-left: 5px solid var(--accent-color);
            padding: 1.5rem;
            margin: 1.5rem 0;
            border-radius: 4px;
        }

        .tts-controls {
            display: flex;
            gap: 10px;
            margin-bottom: 2rem;
        }

        .tts-btn {
            background-color: #2b7fff;
            color: white;
            border: none;
            cursor: pointer;
            width: auto;
            padding: 0.6rem 1.2rem;
        }

        /* Data Matrix Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1.5rem;
        }

        th, td {
            border: 1px solid var(--border-color);
            padding: 0.75rem;
            text-align: left;
        }

        th {
            background-color: var(--bg-secondary);
        }

        fieldset {
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 1rem;
        }
    </style>
</head>
<body>

    <!-- Streamlit Left Control Sidebar -->
    <aside aria-label="Control Panel">
        <h2>🎛️ Control Panel</h2>

        <!-- Accessibility Sub-Engine -->
        <fieldset>
            <legend>Accessibility Engine</legend>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="theme-picker">Display Theme</label>
                <select id="theme-picker" onchange="updateTheme(this.value)">
                    <option value="light">Streamlit Light (Default)</option>
                    <option value="dark">Streamlit Dark Mode</option>
                    <option value="high-contrast">High Contrast (Yellow-on-Black)</option>
                </select>
            </div>
            <div class="form-group">
                <label for="size-picker">Text Scaling</label>
                <select id="size-picker" onchange="updateScale(this.value)">
                    <option value="16px">Normal Text</option>
                    <option value="20px">Large Text</option>
                    <option value="24px">Extra Large Text</option>
                </select>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Civic Social Protection Engine</title>
    <style>
        /* Neutral Civic Color Palette Variables */
        :root {
            --bg-primary: #ffffff;
            --bg-secondary: #f4f6f9;
            --text-color: #212529;
            --accent-color: #0d6efd; /* Civic Blue */
            --border-color: #dee2e6;
            --base-font-size: 16px;
        }

        body {
            font-family: system-ui, -apple-system, sans-serif; /* Uses whatever default open-source system font is installed on Fedora */
            background-color: var(--bg-primary);
            color: var(--text-color);
            font-size: var(--base-font-size);
            margin: 0;
            display: flex;
            min-height: 100vh;
            transition: background 0.2s, color 0.2s, font-size 0.2s;
        }

        /* Generic Left Control Panel Layout */
        aside {
            width: 320px;
            background-color: var(--bg-secondary);
            padding: 2rem 1.5rem;
            border-right: 1px solid var(--border-color);
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Main Workspace Frame Layout */
        main {
            flex: 1;
            padding: 2rem 3rem;
            box-sizing: border-box;
            max-width: 900px;
        }

        h1, h2, h3 {
            margin-top: 0;
            color: var(--text-color);
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        label {
            font-weight: 600;
        }

        select, input, button {
            padding: 0.6rem;
            border-radius: 4px;
            border: 1px solid var(--border-color);
            background-color: var(--bg-primary);
            color: var(--text-color);
            font-size: 1rem;
            box-sizing: border-box;
            width: 100%;
        }

        /* Neutral Button Accent Styling */
        button.run-btn {
            background-color: var(--accent-color);
            color: white;
            border: none;
            font-weight: bold;
            cursor: pointer;
            padding: 0.8rem;
        }

        button.run-btn:hover {
            opacity: 0.9;
        }

        /* Generic Alert / Output Box Styling */
        .output-card {
            background-color: var(--bg-secondary);
            border-left: 5px solid var(--accent-color);
            padding: 1.5rem;
            margin: 1.5rem 0;
            border-radius: 4px;
        }

        .tts-controls {
            display: flex;
            gap: 10px;
            margin-bottom: 2rem;
        }

        .tts-btn {
            background-color: #2b7fff;
            color: white;
            border: none;
            cursor: pointer;
            width: auto;
            padding: 0.6rem 1.2rem;
        }

        /* Data Matrix Styling */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 1.5rem;
        }

        th, td {
            border: 1px solid var(--border-color);
            padding: 0.75rem;
            text-align: left;
        }

        th {
            background-color: var(--bg-secondary);
        }

        fieldset {
            border: 1px solid var(--border-color);
            border-radius: 4px;
            padding: 1rem;
        }

        footer {
            margin-top: 4rem;
            padding-top: 1rem;
            border-top: 1px solid var(--border-color);
            font-size: 0.85rem;
            color: #6c757d;
        }
    </style>
</head>
<body>

    <!-- Left Control Sidebar -->
    <aside aria-label="Control Panel">
        <h2>🎛️ Control Panel</h2>

        <!-- Accessibility Sub-Engine -->
        <fieldset>
            <legend>Accessibility Options</legend>
            <div class="form-group" style="margin-bottom: 1rem;">
                <label for="theme-picker">Display Theme</label>
                <select id="theme-picker" onchange="updateTheme(this.value)">
                    <option value="light">Standard Light Mode</option>
                    <option value="dark">Standard Dark Mode</option>
                    <option value="high-contrast">High Contrast (Yellow-on-Black)</option>
                </select>
            </div>
            <div class="form-group">
                <label for="size-picker">Text Scaling</label>
                <select id="size-picker" onchange="updateScale(this.value)">
                    <option value="16px">Normal Text</option>
                    <option value="20px">Large Text</option>
                    <option value="24px">Extra Large Text</option>
                </select>
            </div>
        </fieldset>

        <!-- Calculation Parameters -->
        <div class="form-group">
            <label for="country-picker">Target Territory</label>
            <select id="country-picker">
                <option value="ng">Nigeria (PenCom Engine)</option>
                <option value="zw">Zimbabwe (NSSA Engine)</option>
            </select>
        </div>

        <div class="form-group">
            <label for="salary-field">Gross Emoluments / Salary</label>
            <input type="number" id="salary-field" value="150000" min="0">
        </div>

        <button class="run-btn" onclick="executeCalculation()">Run Calculation</button>
    </aside>

    <!-- Main Content Frame -->
    <main>
        <header>
            <h1>Civic Social Protection Engine</h1>
            <p>An independent public application verifying statutory civic protections and public policy calculations.</p>
        </header>

        <!-- Dynamic Output Section -->
        <section>
            <h2>Calculation Output</h2>
            <div class="output-card" id="output-box">
                Configure your options in the sidebar control panel and press "Run Calculation" to view results.
            </div>
            
            <div class="tts-controls">
                <button class="tts-btn" onclick="triggerSpeech()">🔊 Read Aloud (English)</button>
                <button class="tts-btn" style="background-color: #555;" onclick="killSpeech()">⏹️ Stop</button>
            </div>
        </section>

        <!-- Localization Matrix -->
        <section style="margin-top: 3rem;">
            <h2>Linguistic Access Table</h2>
            <p>Core system terminology mapped into key regional languages to ensure broad user access:</p>
            
            <table>
                <thead>
                    <tr>
                        <th>English Core Term</th>
                        <th>Igbo Translation (Nigeria)</th>
                        <th>Shona Translation (Zimbabwe)</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td><strong>Salary / Wage</strong></td>
                        <td>Ugwọ Ọrụ</td>
                        <td>Muhoro / Mubhadharo</td>
                    </tr>
                    <tr>
                        <td><strong>Pension Asset</strong></td>
                        <td>Ego Nkamịrị / Ezumike Ẹgụ</td>
                        <td>Chikwama Chemudyandigere</td>
                    </tr>
                    <tr>
                        <td><strong>Unemployment</strong></td>
                        <td>Enweghị Ọrụ</td>
                        <td>Kushaya Basa</td>
                    </tr>
                    <tr>
                        <td><strong>Health Insurance</strong></td>
                        <td>Inshọransị Ahụ Ike</td>
                        <td>Inshurenzi Yehutano</td>
                    </tr>
                </tbody>
            </table>
        </section>

        <!-- Copyleft Public Legal Footer -->
        <footer>
            This software is a Digital Public Good and is protected under the GNU General Public License v3.0 (GPLv3). It is free to use, modify, and distribute.
        </footer>
    </main>

    <script>
        // Theme Manipulation Subroutines
        function updateTheme(mode) {
            const r = document.documentElement;
            if (mode === 'dark') {
                r.style.setProperty('--bg-primary', '#121212');
                r.style.setProperty('--bg-secondary', '#1e1e1e');
                r.style.setProperty('--text-color', '#ffffff');
                r.style.setProperty('--border-color', '#333333');
                r.style.setProperty('--accent-color', '#3788d8');
            } else if (mode === 'high-contrast') {
                r.style.setProperty('--bg-primary', '#000000');
                r.style.setProperty('--bg-secondary', '#111111');
                r.style.setProperty('--text-color', '#ffff00');
                r.style.setProperty('--border-color', '#ffff00');
                r.style.setProperty('--accent-color', '#ffff00');
            } else {
                r.style.setProperty('--bg-primary', '#ffffff');
                r.style.setProperty('--bg-secondary', '#f4f6f9');
                r.style.setProperty('--text-color', '#212529');
                r.style.setProperty('--border-color', '#dee2e6');
                r.style.setProperty('--accent-color', '#0d6efd');
            }
        }

        // Text Scaling Subroutine
        function updateScale(pixels) {
            document.documentElement.style.setProperty('--base-font-size', pixels);
        }

        // Processing Logic Engine
        function executeCalculation() {
            const location = document.getElementById('country-picker').value;
            const wage = parseFloat(document.getElementById('salary-field').value) || 0;
            const container = document.getElementById('output-box');

            if (location === 'ng') {

